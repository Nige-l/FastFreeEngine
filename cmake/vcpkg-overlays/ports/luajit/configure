#!/bin/sh

set -e

LJARCH=
LUAJIT_BUILDMODE=
LUAJIT_BUILDVM_X=
LUAJIT_DASM_ARCHS=
LUAJIT_PREFIX=
LUAJIT_HOST_LUA=
LUAJIT_TARGET_SYS=
LUAJIT_EXECUTABLE_SUFFIX=
for OPTION; do
    case "${OPTION}" in
	--prefix=*)
		LUAJIT_PREFIX="${OPTION#--prefix=}"
		;;
	BUILDMODE=*)
		LUAJIT_BUILDMODE="${OPTION#BUILDMODE=}"
		;;
	BUILDVM_X=*)
		LUAJIT_BUILDVM_X="${OPTION#BUILDVM_X=}"
		;;
	DASM_ARCHS=*)
		LUAJIT_DASM_ARCHS="${OPTION#DASM_ARCHS=}"
		;;
	HOST_LUA=*)
		LUAJIT_HOST_LUA="${OPTION#HOST_LUA=}"
		;;
	LJARCH=*)
		LJARCH="${OPTION#LJARCH=}"
		;;
	TARGET_SYS=*)
		LUAJIT_TARGET_SYS="${OPTION#TARGET_SYS=}"
		;;
	EXECUTABLE_SUFFIX=*)
		LUAJIT_EXECUTABLE_SUFFIX="${OPTION#EXECUTABLE_SUFFIX=}"
		;;
	esac
done

cat > Makefile.vcpkg <<END_MAKEFILE ;

COMMON_OPTIONS += 'E=@:' 'Q='
COMMON_OPTIONS += 'BUILDMODE=${LUAJIT_BUILDMODE}'
COMMON_OPTIONS += 'PREFIX=${LUAJIT_PREFIX}'
COMMON_OPTIONS += 'INSTALL_TNAME=luajit'
COMMON_OPTIONS += 'INSTALL_TSYMNAME=luajit-symlink'

BUILD_OPTIONS += 'CC=${CC}'
BUILD_OPTIONS += 'CCDEBUG='
BUILD_OPTIONS += 'CFLAGS=${CPPFLAGS} ${CFLAGS}'
BUILD_OPTIONS += 'LDFLAGS=${LDFLAGS}'
BUILD_OPTIONS += 'LIBS=${LIBS}'

# TARGET_SYS, EXECUTABLE_SUFFIX, FILE_T, and the Windows library variables must be in
# COMMON_OPTIONS so they are passed to BOTH the build and install make invocations.
# vcpkg_build_make only passes OPTIONS to 'all', NOT to 'install' (vcpkg behaviour),
# so we bake them into COMMON_OPTIONS here.
#
# FILE_T:      top-level Makefile hard-codes luajit; Windows builds produce luajit.exe.
# INSTALL_DEP: dependency check target must match the actual binary filename.
# FILE_A:      MinGW produces libluajit-5.1.dll.a (import library) — not libluajit.a.
# FILE_SO:     MinGW produces lua51.dll — not libluajit.so.
# INSTALL_ANAME: destination filename for the import library in lib/.
# INSTALL_SONAME: destination filename for the DLL in lib/ (Windows: copy to bin/ instead).
ifneq (${LUAJIT_TARGET_SYS},)
COMMON_OPTIONS += 'TARGET_SYS=${LUAJIT_TARGET_SYS}'
endif
ifneq (${LUAJIT_EXECUTABLE_SUFFIX},)
COMMON_OPTIONS += 'EXECUTABLE_SUFFIX=${LUAJIT_EXECUTABLE_SUFFIX}'
COMMON_OPTIONS += 'FILE_T=luajit${LUAJIT_EXECUTABLE_SUFFIX}'
COMMON_OPTIONS += 'INSTALL_DEP=src/luajit${LUAJIT_EXECUTABLE_SUFFIX}'
# Windows dynamic library filenames differ from POSIX naming
COMMON_OPTIONS += 'FILE_A=libluajit-5.1.dll.a'
COMMON_OPTIONS += 'FILE_SO=lua51.dll'
COMMON_OPTIONS += 'INSTALL_ANAME=libluajit-5.1.dll.a'
COMMON_OPTIONS += 'INSTALL_SONAME=lua51.dll'
endif

ifeq (${LJARCH},)
# native
BUILDVM_PREFIX = ${LUAJIT_PREFIX}/manual-tools/luajit
DASM_ARCHS = ${LUAJIT_DASM_ARCHS}
else
# cross
BUILD_OPTIONS += 'HOST_CC=:'
BUILD_OPTIONS += 'BUILDVM_T='
BUILD_OPTIONS += 'BUILDVM_X=${LUAJIT_BUILDVM_X}'
BUILD_OPTIONS += 'HOST_LUA=${LUAJIT_HOST_LUA}'
endif

# used by src/Makefile, best effort from manual '<CC> [-m32] -E src/lj_arch.h -dM'
TARGET_TESTARCH_COMMON += 'LJ_LE 1' 'LJ_HASJIT 1' 'LJ_HASFFI 1' 'LJ_ARCH_HASFPU 1' 'LJ_ABI_SOFTFP 0'
TARGET_TESTARCH_COMMON_32 += \$(TARGET_TESTARCH_COMMON) 'LJ_ARCH_BITS 32'
TARGET_TESTARCH_COMMON_64 += \$(TARGET_TESTARCH_COMMON) 'LJ_ARCH_BITS 64' 'LJ_TARGET_GC64 1'
TARGET_TESTARCH_arm =   \$(TARGET_TESTARCH_COMMON_32) LJ_TARGET_ARM
TARGET_TESTARCH_arm64 = \$(TARGET_TESTARCH_COMMON_64) LJ_TARGET_ARM64 'LJ_ARCH_VERSION 80'
TARGET_TESTARCH_x86 =   \$(TARGET_TESTARCH_COMMON_32) LJ_TARGET_X86
TARGET_TESTARCH_x64 =   \$(TARGET_TESTARCH_COMMON_64) LJ_TARGET_X64 'LJ_FR2 1'

all:
	\$(MAKE) clean \$(COMMON_OPTIONS) \$(BUILD_OPTIONS)
	\$(MAKE) all \$(COMMON_OPTIONS) \$(BUILD_OPTIONS)
	for DA in \$(DASM_ARCHS); do \\
	    rm -f src/host/buildvm_arch.h src/host/*.o; \\
	    case "\$\$DA" in \\
	      arm)   TARGET_TESTARCH="\$(TARGET_TESTARCH_arm)" ;; \\
	      arm64) TARGET_TESTARCH="\$(TARGET_TESTARCH_arm64)" ;; \\
	      x86)   TARGET_TESTARCH="\$(TARGET_TESTARCH_x86)" ;; \\
	      x64)   TARGET_TESTARCH="\$(TARGET_TESTARCH_x64)" ;; \\
	    esac ; \\
	    \$(MAKE) -C src host/buildvm-\$\$DA\$(EXECUTABLE_SUFFIX) \$(COMMON_OPTIONS) \$(BUILD_OPTIONS) \\
	      BUILDVM_T=host/buildvm-\$\$DA\$(EXECUTABLE_SUFFIX) "TARGET_TESTARCH=\$\${TARGET_TESTARCH}" \\
	    || exit 1; \\
	done

install:
	\$(MAKE) install \$(COMMON_OPTIONS) \$(BUILD_OPTIONS)
ifeq (${LJARCH},)
	mkdir -p "\$\${DESTDIR}\$(BUILDVM_PREFIX)"
	install -m 0755 "src/host/minilua\$(EXECUTABLE_SUFFIX)" "\$\${DESTDIR}\$(BUILDVM_PREFIX)/minilua\$(EXECUTABLE_SUFFIX)"
	for DA in \$(DASM_ARCHS); do \\
		install -m 0755 "src/host/buildvm-\$\$DA\$(EXECUTABLE_SUFFIX)" "\$\${DESTDIR}\$(BUILDVM_PREFIX)/buildvm-\$\$DA\$(EXECUTABLE_SUFFIX)" || exit 1 ; \\
	done
endif

END_MAKEFILE
